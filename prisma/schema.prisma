generator client {
  provider = "prisma-client-js"
  // driverAdapters estable en Prisma 7 — no requiere previewFeatures.
  // @prisma/adapter-pg se pasa al constructor en src/lib/prisma/client.ts.
}

datasource db {
  provider = "postgresql"
}

/// Extension of auth.users — auto-created via trigger
model profiles {
  id           String   @id @db.Uuid
  full_name    String?
  company_name String?
  nif          String?
  phone        String?
  role         String   @default("client")
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)

  orders        orders[]
  subscriptions subscriptions[]
}

model orders {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String    @db.Uuid
  product_id            String
  stripe_session_id     String?   @unique
  stripe_payment_intent String?
  amount_cents          Int
  currency              String    @default("eur")
  status                String    @default("intake_pending")
  eidas_level           String
  intake_data           Json?
  intake_completed_at   DateTime? @db.Timestamptz(6)
  // Facturación electrónica (EasyVerifactu — RD 1007/2023)
  invoice_id            String?
  invoice_pdf           String?
  invoiced_at           DateTime? @db.Timestamptz(6)
  // Soft delete — preserva datos para auditoría
  deleted_at            DateTime? @db.Timestamptz(6)
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime  @default(now()) @db.Timestamptz(6)

  user      profiles    @relation(fields: [user_id], references: [id], onDelete: Restrict)
  documents documents[]
  audit_log audit_log[]

  @@index([user_id])
  @@index([status])
  @@index([stripe_session_id])
  @@index([product_id, created_at(sort: Desc)])
}

model documents {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id              String    @db.Uuid
  product_id            String
  version               String    @default("1.0")
  eidas_level           String
  signature_provider    String?
  // Legacy: Documenso document ID (kept for backward-compat while migrating to DocuSeal)
  documenso_document_id String?
  // Generic signing document ID — used by DocuSeal and future providers
  signing_document_id   String?
  signing_provider      String?   @default("docuseal")
  status                String    @default("draft")
  draft_pdf_path        String?
  signed_pdf_path       String?
  hash_sha256_draft     String?
  hash_sha256_signed    String?
  signed_at             DateTime? @db.Timestamptz(6)
  delivery_url_expires  DateTime? @db.Timestamptz(6)
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime  @default(now()) @db.Timestamptz(6)

  order orders @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([documenso_document_id])
  @@index([signing_document_id])
  @@index([status])
}

model audit_log {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event      String
  order_id   String?  @db.Uuid
  user_id    String?  @db.Uuid
  metadata   Json?
  ip_hash    String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  order orders? @relation(fields: [order_id], references: [id], onDelete: SetNull)

  @@index([order_id, created_at(sort: Desc)])
  @@index([event, created_at(sort: Desc)])
}

model monitor_alerts {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source       String
  title        String
  summary      String?
  urgency      String?
  status       String    @default("pending_review")
  raw_url      String?
  published_at DateTime? @db.Date
  areas        String[]
  reviewed_by  String?   @db.Uuid
  reviewed_at  DateTime? @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)

  @@index([status, created_at(sort: Desc)])
}

model subscriptions {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String   @db.Uuid
  product_id             String   @default("AFD-LTK-001")
  stripe_subscription_id String?  @unique
  stripe_customer_id     String?
  status                 String   @default("active")
  normative_profile      Json?
  created_at             DateTime @default(now()) @db.Timestamptz(6)
  updated_at             DateTime @default(now()) @db.Timestamptz(6)

  user profiles @relation(fields: [user_id], references: [id])
}
