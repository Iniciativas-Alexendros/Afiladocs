    "ci:local": "npm run check:env && npm run typecheck && npm run lint && npm run test:coverage && npm run build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
