# ==============================================================================
# AFILADOCS - ENVIRONMENT VARIABLES MAPPING
# ==============================================================================
# Este archivo define la infraestructura de configuración de variables de entorno,
# credenciales, endpoints y puertos necesarios para la orquestación del proyecto.
# 
# INSTRUCCIONES:
# 1. Duplicar este archivo como `.env` para desarrollo local y `.env.production` 
#    para despliegues.
# 2. Las variables documentadas corresponden directamente al schema de validación
#    typo-safe definido en `env.ts`.
# 3. NO COMITEAR archivos `.env` reales conteniendo credenciales activas.
# ==============================================================================

# ─── CORE APPLICATION ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL: URL canónica de la aplicación.
# development: http://localhost:3000 | production: https://afiladocs.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NODE_ENV: Contexto de ejecución del runtime. (development, production, test)
NODE_ENV=development

# ─── SUPABASE (Data, Auth, Storage) ───────────────────────────────────────────
# Variables obtenidas desde Supabase Dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── DATABASE POOL & MIGRATIONS (Supavisor + Prisma) ──────────────────────────
# DATABASE_URL: Conexión mediante connection pooler (Puerto: 6543) - Requerido para Serverless
# NOTA: Supavisor enruta a la instancia primaria en AWS.
DATABASE_URL=postgres://[USER]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# DIRECT_URL: Conexión directa (Puerto: 5432) - Exclusivo para Prisma Migrations y DB Push
DIRECT_URL=postgres://[USER]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ─── STRIPE INFRASCTRUCTURE (Billing & Payments) ──────────────────────────────
# Variables obtenidas desde Stripe Dashboard: Developers > API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# STRIPE_WEBHOOK_SECRET: Firma del webhook (requerido para validar eventos asíncronos de Stripe)
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Stripe Price IDs (Suscripciones y Productos Unitarios) ---
STRIPE_PRICE_LTK_001=price_...  # Legal Tech Kit
STRIPE_PRICE_PCK_001=price_...  # Pack Emprendedor Legal
STRIPE_PRICE_REV_001=price_...  # Revisión Legal de Web
STRIPE_PRICE_INF_001=price_...  # Infoproducto General
STRIPE_PRICE_CON_001=price_...  # Consultoría General

# ─── RESEND (Transactional Email) ─────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@afiladocs.com

# ─── DOCUMENSO (e-Signature Self-Hosted) ──────────────────────────────────────
# Activar la configuración una vez aprovisionado el clúster self-hosted.
DOCUMENSO_API_URL=https://documenso.[DOMAIN].com/api
DOCUMENSO_API_KEY=documenso_secret_...
DOCUMENSO_WEBHOOK_SECRET=documenso_whsec_...

# ─── N8N (Workflow Automation) ────────────────────────────────────────────────
# Credenciales y endpoints para ejecución de playbooks y pipelines offline.
# N8N_INTERNAL_WEBHOOK_SECRET: Token criptográfico compartido (Bearer) entre Afiladocs y n8n
N8N_INTERNAL_WEBHOOK_SECRET=n8n_sec_...
# N8N_CONTACT_WEBHOOK_URL: Endpoint receptor primario en la instancia de n8n
N8N_CONTACT_WEBHOOK_URL=https://n8n.[DOMAIN].com/webhook/contacto/...

# ─── UPSTASH REDIS (Rate Limiting) ───────────────────────────────────────────
# Opcional — sin configurar, rate limiting se desactiva (fallback graceful)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ─── CRON JOBS ───────────────────────────────────────────────────────────────
# CRON_SECRET: Bearer token para autenticar cron jobs de Vercel
CRON_SECRET=cron_sec_...

# ─── DOCUSEAL (e-Signature, activo) ─────────────────────────────────────────
DOCUSEAL_WEBHOOK_SECRET=docuseal_whsec_...

# ─── SENTRY (Error Tracking & Performance) ──────────────────────────────────
# SENTRY_AUTH_TOKEN: Token para subir source maps (en .env.sentry-build-plugin o Vercel env vars)
# DSN hardcodeado en src/sentry.*.config.ts (es clave pública, segura para client bundle)
SENTRY_AUTH_TOKEN=sntrys_...

# ─── EASYVERIFACTU (Invoice Automation) ───────────────────────────────────────
# Integración calendarizada para despliegue diferido
EASYVERIFACTU_API_KEY=ev_...
EASYVERIFACTU_API_URL=https://api.easyverifactu.com/v1
