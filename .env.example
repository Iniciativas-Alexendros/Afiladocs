# ==============================================================================
# AFILADOCS — ENVIRONMENT VARIABLES
# ==============================================================================
# Copia este archivo como .env.local para desarrollo. Las claves aquí son
# espejo del schema validado en src/lib/env.ts.
# NO COMITEAR archivos .env reales.
# ==============================================================================

# ─── CORE ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
NEXT_PUBLIC_APP_VERSION=dev

# ─── SUPABASE (autoalojado) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://supabase.[DOMAIN].com
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── DATABASE (Supavisor + Prisma) ────────────────────────────────────────────
# DATABASE_URL: pooler (6543) — serverless
DATABASE_URL=postgres://postgres.[TENANT]:[PASSWORD]@[SUPAVISOR]:6543/postgres?pgbouncer=true
# DIRECT_URL: directo (5432) — sólo para prisma migrate
DIRECT_URL=postgres://postgres.[TENANT]:[PASSWORD]@[SUPAVISOR]:5432/postgres

# ─── STRIPE ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── RESEND (email transaccional) ────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@afiladocs.com

# ─── DOCUSEAL (firma electrónica, activo) ────────────────────────────────────
DOCUSEAL_API_URL=https://docuseal.[DOMAIN].com
DOCUSEAL_API_KEY=docuseal_...
DOCUSEAL_WEBHOOK_SECRET=docuseal_whsec_...

# ─── STORAGE & SLA ────────────────────────────────────────────────────────────
TEMPLATES_BUCKET=templates
REVIEW_SLA_HOURS=72

# ─── N8N (automations) ────────────────────────────────────────────────────────
N8N_CONTACT_WEBHOOK_URL=https://n8n.[DOMAIN].com/webhook/contacto/...
N8N_ALERTS_WEBHOOK_SECRET=n8n_alerts_sec_...
N8N_ERROR_WEBHOOK_URL=https://n8n.[DOMAIN].com/webhook/errors/...

# ─── UPSTASH REDIS (rate limiting, opcional) ──────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ─── CRON JOBS ────────────────────────────────────────────────────────────────
CRON_SECRET=cron_sec_...

# ─── OPS ──────────────────────────────────────────────────────────────────────
OPS_EMAIL=ops@afiladocs.com
# Lista ISO-3166 alpha-2 separada por comas (ej: "CN,RU"). Vacío = sin geo-block.
GEO_BLOCKED_COUNTRIES=

# ─── EASYVERIFACTU (facturación electrónica, opcional) ───────────────────────
EASYVERIFACTU_API_URL=https://api.easyverifactu.com/v1
EASYVERIFACTU_API_KEY=ev_...

# ─── SENTRY (integración Vercel inyecta OBSERVABILITY_SENTRY_*) ──────────────
# NEXT_PUBLIC_OBSERVABILITY_SENTRY_DSN se inyecta por la integración Vercel+Sentry.
# OBSERVABILITY_SENTRY_AUTH_TOKEN / ORG / PROJECT también. No definir a mano.
